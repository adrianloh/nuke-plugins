# Build outputs (inside any plugin subdirectory)
*/build/
*/cmake-build-*/
*/_stage/
*/out/

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.sln
*.vcxproj*
*.filters

# Compiled plugin binaries
*.dll
*.dylib
*.so
*.obj
*.o
*.pdb
*.ilk
*.exp
*.lib

# ...except for shipped binaries inside any plugin's Release/ directory.
# build.py drops compiled plugins into <plugin>/Release/<platform>/ for
# the team to download via the GitHub web UI.
!*/Release/**/*.dll
!*/Release/**/*.dylib

# NDK tarball (pulled fresh in CI)
ndk.tar.gz
ndk/
nuke-ndk-*/

# IDE
.vs/
.vscode/
.idea/
*.user
*.swp
.DS_Store

# Python
__pycache__/
*.pyc

# Token-stash folders for build.py (see README)
github_pat_*/
